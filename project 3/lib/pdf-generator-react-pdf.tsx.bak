import React from 'react';
import { Document, Page, Text, View, Image, StyleSheet, Font } from '@react-pdf/renderer';
import { format, addDays } from 'date-fns';

const LOGO_BASE64 = 'data:image/webp;base64,';

const styles = StyleSheet.create({
  page: {
    padding: '18mm 22mm 25mm 22mm',
    fontFamily: 'Helvetica',
    fontSize: 10,
    color: '#2C2C2C',
  },
  header: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'center',
    borderBottomWidth: 2.5,
    borderBottomColor: '#B5A184',
    paddingBottom: 14,
    marginBottom: 22,
  },
  logo: {
    width: 88,
    height: 38,
  },
  headerRight: {
    fontSize: 8.5,
    color: '#666',
    textAlign: 'right',
  },
  pageTitle: {
    fontSize: 16,
    fontWeight: 'bold',
    color: '#3D2B1F',
    marginBottom: 20,
  },
  section: {
    marginBottom: 20,
  },
  sectionTitle: {
    fontSize: 9,
    fontWeight: 'bold',
    textTransform: 'uppercase',
    letterSpacing: 1.2,
    color: '#8C7A5E',
    borderBottomWidth: 1,
    borderBottomColor: '#E8E0D6',
    paddingBottom: 6,
    marginBottom: 12,
  },
  angabenGrid: {
    backgroundColor: '#F5F0E8',
    borderRadius: 8,
    padding: '14 18',
    flexDirection: 'row',
    flexWrap: 'wrap',
  },
  angabenItem: {
    width: '50%',
    flexDirection: 'row',
    justifyContent: 'space-between',
    padding: '3 0',
    fontSize: 9.5,
  },
  angabenLabel: {
    color: '#666',
  },
  angabenValue: {
    fontWeight: 'bold',
    color: '#2C2C2C',
  },
  kostenBlock: {
    backgroundColor: '#FDFBF7',
    border: '1 solid #E8E0D6',
    borderRadius: 8,
    padding: '18 20',
  },
  kostenRow: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    padding: '5 0',
    fontSize: 10,
  },
  kostenHeaderRow: {
    fontSize: 11,
    fontWeight: 'bold',
    color: '#3D2B1F',
    paddingBottom: 10,
  },
  kostenSubRow: {
    paddingLeft: 16,
    fontSize: 9.5,
    color: '#666',
  },
  kostenTotal: {
    fontSize: 15,
    fontWeight: 'bold',
    color: '#2D6A4F',
    borderTopWidth: 2.5,
    borderTopColor: '#B5A184',
    marginTop: 10,
    paddingTop: 14,
  },
  kostenAmount: {
    fontWeight: 'bold',
  },
  kostenAmountNegative: {
    fontWeight: 'bold',
    color: '#2D6A4F',
  },
  hinweis: {
    fontSize: 8.5,
    color: '#999',
    fontStyle: 'italic',
    marginTop: 10,
  },
  footer: {
    position: 'absolute',
    bottom: 14,
    left: 22,
    right: 22,
    borderTopWidth: 1,
    borderTopColor: '#E8E0D6',
    paddingTop: 8,
    fontSize: 7.5,
    color: '#999',
    flexDirection: 'row',
    justifyContent: 'space-between',
  },
});

interface LeadData {
  betreuungFuer: string;
  pflegegrad: number;
  mobilitaet: string;
  nachteinsaetze: string;
  deutschkenntnisse: string;
  erfahrung: string;
  vertragsLink?: string;
}

interface KalkulationData {
  bruttopreis: number;
  pflegegeld: number;
  entlastungsbudgetMtl: number;
  steuervorteil: number;
  eigenanteil: number;
}

function formatEuro(amount: number): string {
  return amount.toLocaleString('de-DE', {
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  });
}

function formatDate(date: Date): string {
  return format(date, 'dd.MM.yyyy');
}

const KalkulationPDFDocument: React.FC<{
  lead: LeadData;
  kalkulation: KalkulationData;
}> = ({ lead, kalkulation }) => {
  const today = new Date();
  const gueltigBis = addDays(today, 14);

  return (
    <Document>
      <Page size="A4" style={styles.page}>
        {/* Header */}
        <View style={styles.header}>
          <Image src={LOGO_BASE64} style={styles.logo} />
          <View style={styles.headerRight}>
            <Text>Erstellt am: {formatDate(today)}</Text>
            <Text>Bestpreis-Garantie bis: {formatDate(gueltigBis)}</Text>
          </View>
        </View>

        {/* Page Title */}
        <Text style={styles.pageTitle}>Ihre persönliche Kostenübersicht</Text>

        {/* Angaben Section */}
        <View style={styles.section}>
          <Text style={styles.sectionTitle}>Ihre Angaben</Text>
          <View style={styles.angabenGrid}>
            <View style={styles.angabenItem}>
              <Text style={styles.angabenLabel}>Betreuung für</Text>
              <Text style={styles.angabenValue}>{lead.betreuungFuer}</Text>
            </View>
            <View style={styles.angabenItem}>
              <Text style={styles.angabenLabel}>Pflegegrad</Text>
              <Text style={styles.angabenValue}>{lead.pflegegrad}</Text>
            </View>
            <View style={styles.angabenItem}>
              <Text style={styles.angabenLabel}>Mobilität</Text>
              <Text style={styles.angabenValue}>{lead.mobilitaet}</Text>
            </View>
            <View style={styles.angabenItem}>
              <Text style={styles.angabenLabel}>Nachteinsätze</Text>
              <Text style={styles.angabenValue}>{lead.nachteinsaetze}</Text>
            </View>
            <View style={styles.angabenItem}>
              <Text style={styles.angabenLabel}>Deutschkenntnisse</Text>
              <Text style={styles.angabenValue}>{lead.deutschkenntnisse}</Text>
            </View>
            <View style={styles.angabenItem}>
              <Text style={styles.angabenLabel}>Erfahrung</Text>
              <Text style={styles.angabenValue}>{lead.erfahrung}</Text>
            </View>
          </View>
        </View>

        {/* Kosten Section */}
        <View style={styles.section}>
          <Text style={styles.sectionTitle}>Kostenübersicht</Text>
          <View style={styles.kostenBlock}>
            <View style={[styles.kostenRow, styles.kostenHeaderRow]}>
              <Text>Monatlicher Bruttopreis</Text>
              <Text style={styles.kostenAmount}>{formatEuro(kalkulation.bruttopreis)} €</Text>
            </View>
            <Text style={{ fontSize: 9, color: '#999', paddingVertical: 4 }}>
              Direkt anrechenbare Zuschüsse:
            </Text>
            <View style={[styles.kostenRow, styles.kostenSubRow]}>
              <Text>Pflegegeld (Pflegegrad {lead.pflegegrad})</Text>
              <Text style={styles.kostenAmountNegative}>− {formatEuro(kalkulation.pflegegeld)} €</Text>
            </View>
            <View style={[styles.kostenRow, styles.kostenSubRow]}>
              <Text>Entlastungsbudget (anteilig mtl.)</Text>
              <Text style={styles.kostenAmountNegative}>− {formatEuro(kalkulation.entlastungsbudgetMtl)} €</Text>
            </View>
            <View style={[styles.kostenRow, styles.kostenSubRow]}>
              <Text>Steuervorteil (§35a EStG)</Text>
              <Text style={styles.kostenAmountNegative}>− {formatEuro(kalkulation.steuervorteil)} €</Text>
            </View>
            <View style={[styles.kostenRow, styles.kostenTotal]}>
              <Text>Ihr monatlicher Eigenanteil</Text>
              <Text style={styles.kostenAmount}>{formatEuro(kalkulation.eigenanteil)} €</Text>
            </View>
          </View>
          <Text style={styles.hinweis}>
            Zzgl. Kost & Logis für die Pflegekraft (Verpflegung und eigenes Zimmer, ca. 150–250 €/Monat).
            An- und Abreisekosten sowie Feiertagszuschläge fallen nach Aufwand an.
          </Text>
        </View>

        {/* Footer */}
        <View style={styles.footer} fixed>
          <Text>Primundus GmbH · www.primundus.de · Tel. 0800 123 456 78</Text>
          <Text render={({ pageNumber, totalPages }) => `Seite ${pageNumber} von ${totalPages}`} />
        </View>
      </Page>
    </Document>
  );
};

export async function generateKalkulationPDF(
  lead: LeadData,
  kalkulation: KalkulationData
): Promise<Buffer> {
  const { renderToBuffer } = await import('@react-pdf/renderer');
  const pdfDocument = <KalkulationPDFDocument lead={lead} kalkulation={kalkulation} />;
  return renderToBuffer(pdfDocument);
}
