# Public site URL — used by SMTP templates and SEO meta.
NEXT_PUBLIC_SITE_URL=https://kostenrechner.primundus.de

# CA app (kundenportal) — handoff target after the calculator result page.
# The result page redirects the customer here with ?token=<lead.token>.
# The Eingangsbestätigung email also embeds this URL as a magic link.
# Local dev: http://localhost:5173
NEXT_PUBLIC_PORTAL_URL=https://kundenportal.primundus.de

# Admin login (server-only).
ADMIN_PASSWORD=

# Supabase (public anon key + URL).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only — used by API routes that must bypass RLS).
SUPABASE_SERVICE_ROLE_KEY=

# SMTP (Ionos).
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Primundus 24h-Pflege
SMTP_ADMIN_EMAIL=
